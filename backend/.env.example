# ============================
# Application Settings
# ============================
APP_NAME=AI Travel Recommendation Backend
APP_ENV=development
APP_DEBUG=true

# ============================
# Database Configuration
# ============================
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/muterbdg_db

# ============================
# JWT Configuration (Phase 2)
# ============================
JWT_SECRET_KEY=change_this_later
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================
# CORS / Frontend
# ============================
FRONTEND_URL=http://localhost:3000
# Comma-separated extra CORS origins for LAN/staging (e.g. local IP, ngrok, Vercel preview)
# CORS_ORIGINS=http://192.168.110.246:3000,https://abc123.ngrok-free.app,https://your-preview.vercel.app
CORS_ORIGINS=

# ============================
# External AI API Keys (Required for Chatbot & Planner)
# ============================
OPENROUTER_API_KEY=
MUTERBANDUNG_ENABLE_ONLINE_CHAT_LLM=true
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
