# MuterBandung / PIJAK local environment example.
# Copy this file to .env for local development.

# Flask server
HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=false

# Embedding model behavior.
# Leave MUTERBANDUNG_MODEL_PATH empty to let sentence-transformers use the
# default Hugging Face cache/download behavior.
MUTERBANDUNG_MODEL_PATH=
HF_HOME=
HUGGINGFACE_HUB_CACHE=
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0

# API test/evaluation target
MUTERBANDUNG_API_URL=http://127.0.0.1:5000/api/recommend

# Cloudflare Workers AI / RAG / query parser
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_MODEL=@cf/meta/llama-3.1-8b-instruct

# Groundtruth evaluator
GROUNDTRUTH_PATH=Dataset/3_Curated/groundtruth_queries.csv
GROUNDTRUTH_REPORT_PATH=groundtruth_eval_report.md
GROUNDTRUTH_JSON_PATH=groundtruth_eval_results.json
GROUNDTRUTH_REQUEST_TIMEOUT=30
GROUNDTRUTH_PREFLIGHT_TIMEOUT=30
GROUNDTRUTH_TOP_CHECK=3

# QC runner
QC_REPORT_PATH=qc_report.md
QC_ATOMIC_REPORT=true
QC_REQUEST_TIMEOUT=30
QC_PREFLIGHT_TIMEOUT=30
QC_USER_LAT=-6.9147
QC_USER_LON=107.6098
