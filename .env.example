# MuterBandung — Environment Variables
# Copy this file to .env for local development.

# ── Server ──
HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=false

# ── Dataset Paths ──
# By default, the backend looks inside ai_workspace/ for datasets.
# Override via env var if needed:
# MUTERBANDUNG_DATASET_PATH=
# MUTERBANDUNG_OLEH_OLEH_DATASET_PATH=

# ── Embedding Model ──
# Leave empty to use default Hugging Face cache behavior.
MUTERBANDUNG_MODEL_PATH=
HF_HOME=
HUGGINGFACE_HUB_CACHE=
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0

# ── API Test Target ──
MUTERBANDUNG_API_URL=http://127.0.0.1:5000/api/recommend

# ── Groundtruth Evaluator ──
GROUNDTRUTH_PATH=ai_workspace/Wisata_Workspace/01_Dataset/3_Curated/groundtruth_queries.csv
GROUNDTRUTH_REPORT_PATH=groundtruth_eval_report.md
GROUNDTRUTH_JSON_PATH=groundtruth_eval_results.json
GROUNDTRUTH_REQUEST_TIMEOUT=30
GROUNDTRUTH_PREFLIGHT_TIMEOUT=30
GROUNDTRUTH_TOP_CHECK=3

# ── QC Runner ──
QC_REPORT_PATH=qc_report.md
QC_ATOMIC_REPORT=true
QC_REQUEST_TIMEOUT=30
QC_PREFLIGHT_TIMEOUT=30
QC_USER_LAT=-6.9147
QC_USER_LON=107.6098
